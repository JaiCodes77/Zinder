# Redis connection URI
REDIS_URL=redis://localhost:6379/0

# Gateway Port
PORT=8080

# JSON serialized list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:5174"]

# Shared secret between gateway and internal microservices (required)
INTERNAL_SERVICE_SECRET=zinder-dev-internal-secret-change-me

# Downstream service URLs
PROFILE_SERVICE_URL=http://localhost:8081
MATCHER_SERVICE_URL=http://localhost:8082
CHAT_SERVICE_URL=http://localhost:8083

# Dev-only: auto-like-back for @zinder.internal seed accounts (default: false)
SEED_AUTO_LIKE=false
